# Backend URL – used only by Next.js rewrites (server-side). Not exposed to the client.
# Optional: set in .env.local to override the default (e.g. for a different backend).
BACKEND_URL=https://backend.skinme.store

# Optional: public API base path. Default is /api/v1 (same-origin via rewrites).
NEXT_PUBLIC_API_BASE=/api/v1

# Optional: public base for uploads. Leave empty to use same-origin /uploads (via rewrites).
NEXT_PUBLIC_UPLOADS_BASE=

# Google OAuth client ID (Web application) for "Login with Google". Get from Google Cloud Console.
# Leave empty to hide the Google login button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: Google Maps API key for delivery address (Places Autocomplete + Geocoding).
# Enables "Search with Google Maps" and "Use current location" on checkout.
# Enable Maps JavaScript API and Geocoding API in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyDdqxsw4uCUbj5Nqdvly9cxJXOjnY4rIvI
