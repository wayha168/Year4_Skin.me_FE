# Backend URL – used only by Next.js rewrites (server-side). Not exposed to the client.
# Local Spring Boot example: BACKEND_URL=http://localhost:8800
# Restart `npm run dev` after changing this.
BACKEND_URL=https://backend.skinme.store
# BACKEND_URL=http://localhost:8800

# Optional: public API base path. Default is /api/v1 (same-origin via rewrites).
NEXT_PUBLIC_API_BASE=/api/v1

# Chat assistant API - uses Next.js rewrites at /api/chatbot (no longer needed)

# Optional: public base for uploads. Leave empty to use same-origin /uploads (via rewrites).
NEXT_PUBLIC_UPLOADS_BASE=

# Google Sign-In (browser)
# Spring redirect-uri=https://skinme.store/oauth-callback is for server redirect OAuth, not the SPA popup flow.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=732985381497-9b1i77bicachait2uqpd79vaj6bmdehf.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=postmessage

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyDdqxsw4uCUbj5Nqdvly9cxJXOjnY4rIvI